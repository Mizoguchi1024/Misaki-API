<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.mizoguchi.misaki.mapper.ModelMapper">
    <insert id="insertModel">
        INSERT INTO model
            <trim prefix="(" suffix=")" suffixOverrides=",">
                <if test="name != null">name,</if>
                <if test="grade != null">grade,</if>
                <if test="path != null">path,</if>
                <if test="avatarPath != null">avatar_path,</if>
            </trim>
            <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
                <if test="name != null">#{name},</if>
                <if test="grade != null">#{grade},</if>
                <if test="path != null">#{path},</if>
                <if test="avatarPath != null">#{avatarPath},</if>
            </trim>
    </insert>
    <select id="selectModelById" resultType="org.mizoguchi.misaki.pojo.entity.Model">
        SELECT * FROM model WHERE id = #{id}
    </select>
    <update id="updateModel">
        UPDATE model
            <set>
                <if test="name != null">name = #{name},</if>
                <if test="grade != null">grade = #{grade},</if>
                <if test="path != null">path = #{path},</if>
                <if test="avatarPath != null">avatar_path = #{avatarPath},</if>
            </set>
        WHERE id = #{id}
    </update>
    <delete id="deleteModelById">
        DELETE FROM model WHERE id = #{id}
    </delete>

</mapper>