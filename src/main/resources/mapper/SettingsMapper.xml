<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.mizoguchi.misaki.mapper.SettingsMapper">
    <select id="selectSettingsByUserId" resultType="org.mizoguchi.misaki.pojo.entity.Settings">
        SELECT * FROM settings
        WHERE user_id = #{userId}
    </select>

    <insert id="insertSettings" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO settings
            <trim prefix="(" suffix=")" suffixOverrides=",">
                <if test="userId != null">user_id,</if>
                <if test="appearance != null">appearance,</if>
                <if test="language != null">language,</if>
                <if test="ttsAutoplay != null">tts_autoplay,</if>
                <if test="fontSize != null">font_size,</if>
                <if test="colorPrimary != null">color_primary,</if>
                <if test="borderRadius != null">border_radius,</if>
                <if test="backgroundImagePath != null">background_image_path,</if>
                <if test="enabledAssistantId != null">enabled_assistant_id,</if>
            </trim>
        VALUES
            <trim prefix="(" suffix=")" suffixOverrides=",">
                <if test="userId != null">#{user_id},</if>
                <if test="appearance != null">#{appearance},</if>
                <if test="language != null">#{language},</if>
                <if test="ttsAutoplay != null">#{tts_autoplay},</if>
                <if test="fontSize != null">#{font_size},</if>
                <if test="colorPrimary != null">#{color_primary},</if>
                <if test="borderRadius != null">#{border_radius},</if>
                <if test="backgroundImagePath != null">#{background_image_path},</if>
                <if test="enabledAssistantId != null">#{enabled_assistant_id},</if>
            </trim>
    </insert>
    <update id="updateSettingsByUserId">
        UPDATE settings
        <set>
            <if test="appearance != null">appearance = #{appearance},</if>
            <if test="language != null">language = #{language},</if>
            <if test="ttsAutoplay != null">tts_autoplay = #{ttsAutoplay},</if>
            <if test="fontSize !=null">font_size = #{fontSize},</if>
            <if test="colorPrimary != null">color_primary = #{colorPrimary},</if>
            <if test="borderRadius != null">border_radius = #{borderRadius},</if>
            <if test="backgroundImagePath != null">background_image_path = #{backgroundImagePath}</if>
            <if test="enabledAssistantId != null">enabled_assistant_id = #{enabledAssistantId},</if>
        </set>
        WHERE user_id = #{userId}
    </update>
</mapper>